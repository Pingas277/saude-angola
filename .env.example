# =============================================================================
# Saúde Angola — environment variables
# Copy to .env.local and fill in. Never commit .env.local.
# =============================================================================

# --- Supabase --- (required)
# Project URL — found at: Supabase dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Publishable (anon) key — found at: Supabase dashboard → Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Postgres connection string — used only by `npm run migrate`. Never exposed to
# the browser. Found at: Supabase dashboard → Settings → Database → Connection
# string (URI). On Vercel, set this only in Production scope.
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# --- Claude API --- (optional)
# When present, telemedicine triage uses Claude Haiku 4.5 for the urgency
# classification + clinical summary. When absent, falls back to a keyword
# heuristic. Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Email (Resend) --- (recommended)
# Transactional emails: booking confirmation, lab result, prescription,
# invoice. Sign up at https://resend.com, verify lunga.ao as a sending
# domain (SPF/DKIM/MX DNS records), then drop the API key here.
RESEND_API_KEY=
# Optional. Override the From header. Defaults to 'Lunga <no-reply@lunga.ao>'.
EMAIL_FROM=
# Optional. BCC every transactional email to this address — useful for
# QA in pre-launch. Leave empty in production.
EMAIL_BCC=
